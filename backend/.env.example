# ── LLM Providers ──────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Telegram Bot ────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
# UUID of the agent that receives Telegram messages
TELEGRAM_GATEWAY_AGENT_ID=uuid_of_your_gateway_agent_from_ui

# ── App Settings ────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/platform.db
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Optional: Slack ─────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ── Optional: Groq (FREE tier) ──────────────────────────────────
# Get free key at: https://console.groq.com
# Supports: llama-3.1-8b-instant, llama3-70b-8192, mixtral-8x7b-32768
GROQ_API_KEY=your_groq_api_key_here
